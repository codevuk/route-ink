exports[`createQueryFile > get-with-params (params only) > produces the correct output 1`] = `
"// ------------------------------
// Auto-generated query file for GET /users/:id
// This file is generated by Route Ink. Do not edit manually.
// ------------------------------
import { useSuspenseQuery, UseSuspenseQueryOptions } from "@tanstack/react-query";
import axios from "axios";
import { Except } from "type-fest";
import z from "zod/v4";
import { UserSchema, UserParamsSchema } from "@workspace/schemas";
import { buildQueryKey, injectParams } from "../util";




type GetUserSuspenseQueryInput = {
  params: z.output<typeof UserParamsSchema>;
};

export const useGetUserSuspenseQuery = (input: GetUserSuspenseQueryInput, options?: Except<UseSuspenseQueryOptions<z.infer<typeof UserSchema>>, "queryFn">) => {
  const { params } = input;

  const url = injectParams("/users/:id", UserParamsSchema, params);

  const queryKey = options?.queryKey || buildQueryKey(url);

  return useSuspenseQuery({
    queryKey,
    queryFn: async (context) => {
      const response = await axios.get(url, {
        signal: context.signal,
      });

      return UserSchema.parse(response.data);
    },
    ...options,
  });
};"
`;

exports[`createQueryFile > get-with-query (query only) > produces the correct output 1`] = `
"// ------------------------------
// Auto-generated query file for GET /users
// This file is generated by Route Ink. Do not edit manually.
// ------------------------------
import { useSuspenseQuery, UseSuspenseQueryOptions } from "@tanstack/react-query";
import axios from "axios";
import { Except } from "type-fest";
import z from "zod/v4";
import { UserSchema, UserQuerySchema } from "@workspace/schemas";
import { buildQueryKey, serializeSearchQuery } from "../util";




type GetUsersSuspenseQueryInput = {
  query: z.output<typeof UserQuerySchema>;
};

export const useGetUsersSuspenseQuery = (input: GetUsersSuspenseQueryInput, options?: Except<UseSuspenseQueryOptions<z.infer<typeof UserSchema>>, "queryFn">) => {
  const { query } = input;
  const url = "/users";

  const searchQuery = serializeSearchQuery(query);

  const queryKey = options?.queryKey || buildQueryKey(url, query);

  return useSuspenseQuery({
    queryKey,
    queryFn: async (context) => {
      const response = await axios.get(\`\${url}?\${searchQuery}\`, {
        signal: context.signal,
      });

      return UserSchema.parse(response.data);
    },
    ...options,
  });
};"
`;

exports[`createQueryFile > get-with-query-and-params (both) > produces the correct output 1`] = `
"// ------------------------------
// Auto-generated query file for GET /users/:id/posts
// This file is generated by Route Ink. Do not edit manually.
// ------------------------------
import { useSuspenseQuery, UseSuspenseQueryOptions } from "@tanstack/react-query";
import axios from "axios";
import { Except } from "type-fest";
import z from "zod/v4";
import { UserSchema, UserParamsSchema, PostQuerySchema } from "@workspace/schemas";
import { buildQueryKey, injectParams, serializeSearchQuery } from "../util";





type GetUserPostsSuspenseQueryInput = {
  params: z.output<typeof UserParamsSchema>;
  query: z.output<typeof PostQuerySchema>;
};

export const useGetUserPostsSuspenseQuery = (input: GetUserPostsSuspenseQueryInput, options?: Except<UseSuspenseQueryOptions<z.infer<typeof UserSchema>>, "queryFn">) => {
  const { params, query } = input;

  const url = injectParams("/users/:id/posts", UserParamsSchema, params);
  const searchQuery = serializeSearchQuery(query);

  const queryKey = options?.queryKey || buildQueryKey(url, query);

  return useSuspenseQuery({
    queryKey,
    queryFn: async (context) => {
      const response = await axios.get(\`\${url}?\${searchQuery}\`, {
        signal: context.signal,
      });

      return UserSchema.parse(response.data);
    },
    ...options,
  });
};
"
`;
