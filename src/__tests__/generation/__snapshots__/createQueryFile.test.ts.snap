// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`createQueryFile > complex response schema > produces the correct output with complex response schema 1`] = `
"// ------------------------------
// Auto-generated query file for GET /users
// This file is generated by Route Ink. Do not edit manually.
// ------------------------------
import { useSuspenseQuery, UseSuspenseQueryOptions } from "@tanstack/react-query";
import axios from "axios";
import { Except } from "type-fest";
import z from "zod/v4";
import { UserSchema } from "@workspace/schemas";
import { buildQueryKey } from "../util";

const ResponseSchema = PaginatedResponse(UserSchema);

export const useGetUsersSuspenseQuery = (options?: Except<UseSuspenseQueryOptions<z.infer<typeof ResponseSchema>>, "queryFn">) => {
  const url = "/users";
  const queryKey = options?.queryKey || buildQueryKey(url);

  return useSuspenseQuery({
    queryKey,
    queryFn: async (context) => {
      const response = await axios.get(url, {
        signal: context.signal,
      });

      return ResponseSchema.parse(response.data);
    },
    ...options,
  });
};
"
`;

